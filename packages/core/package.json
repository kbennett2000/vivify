{
  "name": "@vivify/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --build --pretty && tsc -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "dev": "tsc --build && vite serve dev",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@vivify/acs": "workspace:*",
    "@vivify/types": "workspace:*"
  },
  "devDependencies": {
    "vite": "^6.0.5"
  }
}
